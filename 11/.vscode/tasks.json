{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build main (main + Lambda)",
      "type": "shell",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-Wall",
        "${workspaceFolder}/main.cpp",
        "${workspaceFolder}/Lambda.cpp",
        "-o",
        "${workspaceFolder}/main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
